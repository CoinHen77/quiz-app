rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Readable by anyone for player game flow.
    // Writable by anyone — acceptable for a one-time event where the only
    // write surface is the password-gated host UI.
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
